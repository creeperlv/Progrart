<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:progrart="using:Progrart"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Progrart.Controls.TabSystem.TabHost">
	<Border>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>
			<Border Margin="12" Background="#2888" CornerRadius="16" Padding="8,0">
				<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
					<StackPanel Name="TabContainer" Orientation="Horizontal" Margin="4">
						<StackPanel.Styles>
							<Style Selector="Button">
								<Setter Property="CornerRadius" Value="12"/>
							</Style>
						</StackPanel.Styles>
						<TextBlock Margin="0,4"/>
					</StackPanel>
				</ScrollViewer>
			</Border>
			<Border Grid.Row="1" Background="#2888" CornerRadius="6">

				<Grid Name="PageContainer">
				</Grid>
			</Border>
		</Grid>
	</Border>
</UserControl>
